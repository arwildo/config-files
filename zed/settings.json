{
  "code_actions_on_format": {
    "source.fixAll.eslint": true
  },
  "formatter": [],
  "languages": {
    "Java": {
      "language_servers": ["-jdtls"]
    },
    "Plain Text": {
      "enable_language_server": false
    },
    "CSS": {
      "enable_language_server": false
    },
    "TypeScript": {
      "language_servers": ["!vtsls", "!eslint", "..."],
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "JavaScript": {
      "language_servers": ["!vtsls", "!eslint", "..."],
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "TSX": {
      "language_servers": ["!vtsls", "!eslint", "..."],
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "JSX": {
      "language_servers": ["!vtsls", "!eslint", "..."],
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    }
  },
  "agent": {
    "default_profile": "write",
    "inline_assistant_model": {
      "provider": "deepseek",
      "model": "deepseek-chat"
    },
    "default_model": {
      "provider": "deepseek",
      "model": "deepseek-chat"
    },
    "model_parameters": []
  },
  "base_keymap": "VSCode",
  "vim_mode": true,
  "ui_font_size": 13,
  "buffer_font_size": 13,
  "diagnostics": {
    "enabled": false
  },
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "format_on_save": "on",
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  }
}
